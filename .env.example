# 11408study 根级 .env 模板
# 用法:cp .env.example .env, 填值后启动 docker compose
# .env 已在 .gitignore 中,不会被提交

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=study11408
POSTGRES_USER=study11408
# openssl rand -base64 24 | tr -d '=+/'
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ─── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=study11408
# openssl rand -base64 24 | tr -d '=+/'
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
MINIO_BUCKET=study11408

# ─── Spring Boot Profile ────────────────────────────────────────────────────
# 生产必须为 prod, 否则不会触发 application-prod.yml 的强制校验
SPRING_PROFILES_ACTIVE=prod

# ─── Backend / JWT ──────────────────────────────────────────────────────────
# openssl rand -base64 64 | tr -d '\n'
APP_JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_64_and_paste_here

# ─── CORS 白名单(逗号分隔, 生产填真实域名) ────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com

# ─── Mail (QQ SMTP 示例) ────────────────────────────────────────────────────
# QQ 邮箱 → 设置 → 账户 → 开启 IMAP/SMTP 服务 → 生成授权码(16 位)
# 注意:MAIL_PASSWORD 填授权码,不是 QQ 登录密码
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_qq_id@qq.com
MAIL_PASSWORD=your_16_char_qq_smtp_auth_code
MAIL_FROM=your_qq_id@qq.com
MAIL_FROM_NAME=11408 学习平台

# ─── Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile) ────────
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxx
# 前端 build-time 注入(必须以 NEXT_PUBLIC_ 开头才会暴露到客户端)
# 测试 sitekey: 1x00000000000000000000AA (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── Monitoring profile ─────────────────────────────────────────────────────
# 仅 docker compose --profile monitoring up -d 时启用
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ─── 站点域名(给 nginx + Certbot 用) ──────────────────────────────────────
DOMAIN=your-domain.com
ACME_EMAIL=you@example.com
